# Strongly recommended so strangers cannot consume your Railway bandwidth.
APP_PASSWORD=change-this-password

# Maximum simultaneous yt-dlp jobs.
MAX_CONCURRENT_DOWNLOADS=2

# Maximum queued + active jobs held by this single app instance.
MAX_QUEUED_JOBS=10

# Per-IP download starts allowed during a rolling hour.
MAX_JOBS_PER_HOUR=20

# Four hours. Change this if you need longer videos.
MAX_DURATION_SECONDS=14400

# Completed files expire after 30 minutes.
COMPLETED_JOB_TTL_SECONDS=1800

# Optional: base64-encoded Netscape cookies.txt file.
# YOUTUBE_COOKIES_B64=

# Maximum size of a per-download cookies.txt upload (2 MiB).
MAX_COOKIE_FILE_BYTES=2097152

# AdSense verification is already configured for this publisher.
ADSENSE_CLIENT_ID=ca-pub-4820082513371524

# Create three responsive Display ad units in AdSense and paste only each numeric slot ID.
# Leave blank to hide that manual ad location. Auto ads can still work through the head script.
ADSENSE_HEADER_SLOT=
ADSENSE_MIDDLE_SLOT=
ADSENSE_FOOTER_SLOT=
